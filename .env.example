# Want to use another LLM provider with the Anthropic SDK ? Use these and comment the above values :
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_BASE_URL="..."
ANTHROPIC_API_KEY=sk-ant-...

