# Telegram parameters
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Want to use Claude ? Use the following and comment the SNCF GPT part :
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
